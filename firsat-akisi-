        <button onClick={onAddNew} className="press" style={{ padding: "12px", borderRadius: 11, border: `1.5px dashed ${T.blue}66`, background: T.blueSoft, color: T.blue, cursor: "pointer", fontSize: 14, fontWeight: 700, fontFamily: T.disp }}>
