    <div onClick={onClose} style={{ position: "fixed", inset: 0, background: "rgba(23,26,33,.5)", zIndex: 50, display: "flex", alignItems: "center", justifyContent: "center", padding: 20, animation: "fadeIn .2s" }}>
      <div onClick={(e) => e.stopPropagation()} style={{ background: T.card, borderRadius: 18, padding: 26, width: "100%", maxWidth: 460, maxHeight: "80vh", display: "flex", flexDirection: "column", animation: "popIn .28s cubic-bezier(.22,1,.36,1)" }}>
